// Filename:-	modview_version.h
//
// This header is GENERATED by CMake from modview_version.h.in. Do not edit the
// generated copy in build/generated - change modview_version.h.in instead.
// The CI workflow overrides MODVIEW_VERSION_STRING at configure time so each
// release gets its own version number; local dev builds fall back to the
// defaults wired into CMakeLists.txt.

#ifndef MODVIEW_VERSION_H
#define MODVIEW_VERSION_H

#define MODVIEW_VERSION_MAJOR			@MODVIEW_VERSION_MAJOR@
#define MODVIEW_VERSION_MINOR			@MODVIEW_VERSION_MINOR@
#define MODVIEW_VERSION_PATCH			@MODVIEW_VERSION_PATCH@

// Short marketing string used in the About dialog and window captions (e.g.
// "3.4"). Keep this short - the About text appends "ModView Version " to it.
#define MODVIEW_VERSION_STRING			"@MODVIEW_VERSION_STRING@"

// 4-component string used in the Win32 VS_VERSION_INFO VALUEs. Rendered with
// spaces and commas because that's the historical Raven format.
#define MODVIEW_VERSION_STRING_DOTTED	"@MODVIEW_VERSION_MAJOR@, @MODVIEW_VERSION_MINOR@, @MODVIEW_VERSION_PATCH@, 0"

#endif	// MODVIEW_VERSION_H
